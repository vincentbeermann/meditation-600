rules_version = '2';

// Meditation 600 — each signed-in user owns exactly their own session subtree.
// No cross-user access; unauthenticated requests are denied everywhere.
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner-only access to any subcollection under their own user doc
    // (sessions, pushTokens, future additions).
    match /users/{uid}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
